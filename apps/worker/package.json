{
  "name": "@pred/worker",
  "version": "0.0.1",
  "description": "Pred.game BullMQ worker process",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main",
    "start:dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@pred/application": "workspace:*",
    "@pred/domain": "workspace:*",
    "@pred/infrastructure": "workspace:*",
    "@pred/shared": "workspace:*",
    "bullmq": "^5.15.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "pino-pretty": "^13.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
