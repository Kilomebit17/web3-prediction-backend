# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────────────────
# Railway: auto-provided when you add PostgreSQL plugin
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pred?schema=public
DATABASE_POOL_MAX=20

# ── Redis ──────────────────────────────────────────────────────────────────────
# Railway: auto-provided when you add Redis plugin
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate keys: openssl genpkey -algorithm RSA -out secrets/jwt.private.pem -pkeyopt rsa_keygen_bits:2048
#                 openssl pkey -in secrets/jwt.private.pem -pubout -out secrets/jwt.public.pem
# For Railway: copy key files into the image or use env vars (see railway.toml)
JWT_PRIVATE_KEY_PATH=./secrets/jwt.private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt.public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=pred.game
JWT_AUDIENCE=pred.game.api

# ── Telegram ───────────────────────────────────────────────────────────────────
# Create bot via @BotFather, paste token here
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_DATA_TTL=86400
TELEGRAM_FRESH_INITDATA_TTL=60
TELEGRAM_ANTIREPLAY_ENABLED=true

# ── External APIs ──────────────────────────────────────────────────────────────
BINANCE_BASE_URL=https://data-api.binance.vision
BINANCE_TIMEOUT_MS=5000

# ── Game Constants ─────────────────────────────────────────────────────────────
INITIAL_BALANCE=1000
MAX_BET_PERCENT_OF_BALANCE=50
BET_MIN_DURATION_SECONDS=30

# ── Rate Limits ────────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MIN=30
RATE_LIMIT_BETS_PER_MIN=60
RATE_LIMIT_READ_PER_MIN=300

# ── CORS (set in production to your Vercel domain) ─────────────────────────────
# CORS_ORIGIN=https://your-app.vercel.app

# ── Observability (optional) ───────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=
# SENTRY_DSN=
